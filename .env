# WordPress REST API base URL — no trailing slash
#
# Local development (LocalWP):
#VITE_WP_API_URL=http://perth-bangla-cafe.local/wp-json/wp/v2

# Live site (Personal Hosting) — uncomment and update when deploying:
VITE_WP_API_URL=http://perthbanglacafe.store/wp-json/wp/v2

# Your Custom Post Type slug — must match what you registered in WordPress
# e.g. if your CPT slug is "menu-items", set: VITE_CPT_SLUG=menu-items
VITE_CPT_SLUG=menu
